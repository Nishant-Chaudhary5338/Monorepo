{
  "name": "nivanta-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5181",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:visual:headed": "playwright test tests/visual.spec.ts --headed",
    "test:interaction": "playwright test tests/interaction.spec.ts",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:performance": "playwright test tests/performance.spec.ts",
    "test:all": "playwright test",
    "test:report": "playwright show-report",
    "ci": "pnpm build && pnpm test:all"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "framer-motion": "^11.18.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.56.0",
    "react-router-dom": "^7.14.0",
    "resend": "^6.12.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/vite": "^4.1.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^15.0.0",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0"
  }
