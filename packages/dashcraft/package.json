{
  "name": "@repo/dashcraft",
  "version": "0.1.0",
  "description": "Headless interactive dashboard library for React. Craft dashboards, not headaches.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./dist/index.css",
    "./card": {
      "types": "./dist/components/DashboardCard/index.d.ts",
      "import": "./src/components/DashboardCard/index.ts"
    },
    "./widgets": {
      "types": "./dist/widgets/index.d.ts",
      "import": "./src/widgets/index.ts"
    },
    "./widgets/recharts": {
      "types": "./dist/widgets/recharts/index.d.ts",
      "import": "./src/widgets/recharts/index.ts"
    },
    "./widgets/nivo": {
      "types": "./dist/widgets/nivo/index.d.ts",
      "import": "./src/widgets/nivo/index.ts"
    },
    "./widgets/kpi": {
      "types": "./dist/widgets/kpi/index.d.ts",
      "import": "./src/widgets/kpi/index.ts"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./src/hooks/index.ts"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./src/store/index.ts"
    },
    "./http": {
      "types": "./dist/utils/http-client.d.ts",
      "import": "./src/utils/http-client.ts"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./src/utils/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "dev": "tsc --watch",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "lint": "eslint \"**/*.ts\" \"**/*.tsx\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^1.7.0",
    "re-resizable": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "@nivo/core": ">=0.87.0",
    "@nivo/heatmap": ">=0.87.0",
    "@nivo/sunburst": ">=0.87.0",
    "@nivo/treemap": ">=0.87.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "recharts": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    },
    "@nivo/core": {
      "optional": true
    },
    "@nivo/heatmap": {
      "optional": true
    },
    "@nivo/treemap": {
      "optional": true
    },
    "@nivo/sunburst": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nivo/core": "^0.87.0",
    "@nivo/heatmap": "^0.87.0",
    "@nivo/sunburst": "^0.87.0",
    "@nivo/treemap": "^0.87.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}