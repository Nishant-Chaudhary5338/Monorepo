{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./styles.css": "./dist/index.css",
    "./lib/utils": "./lib/utils.ts",
    "./counter": "./components/counter.ts",
    "./header": "./components/header.ts",
    "./setup-counter": "./utils/counter.ts"
  },
  "license": "MIT",
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint \"**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "component:generate": "component-factory generate $npm_config_name",
    "component:review": "review components/$npm_config_name",
    "component:fix": "fix components/$npm_config_name",
    "component:improve": "improve components/$npm_config_name",
    "workflow": "pnpm component:generate $npm_config_name && pnpm component:fix --name=$npm_config_name && pnpm component:improve --name=$npm_config_name && pnpm test && pnpm component:review --name=$npm_config_name",
    "workflow:full": "pnpm component:generate $npm_config_name && pnpm component:fix --name=$npm_config_name && pnpm component:improve --name=$npm_config_name && pnpm test:watch && pnpm component:review --name=$npm_config_name"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@repo/cli-wrappers": "workspace:*",
    "@repo/component-tools": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "component-factory-mcp": "workspace:*",
    "component-fixer-mcp": "workspace:*",
    "component-improver-mcp": "workspace:*",
    "component-reviewer-mcp": "workspace:*",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.5",
    "typescript": "5.5.4",
    "vitest": "^4.1.0"
  }
}
