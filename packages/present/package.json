{
  "name": "@repo/present",
  "version": "0.0.1",
  "description": "Production-grade React presentation library — layouts, fullscreen, animations, Prezi-like web presentations, and beautiful components.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core.d.ts"
    },
    "./state": {
      "import": "./dist/state.js",
      "require": "./dist/state.cjs",
      "types": "./dist/state.d.ts"
    },
    "./animation": {
      "import": "./dist/animation.js",
      "require": "./dist/animation.cjs",
      "types": "./dist/animation.d.ts"
    },
    "./gestures": {
      "import": "./dist/gestures.js",
      "require": "./dist/gestures.cjs",
      "types": "./dist/gestures.d.ts"
    },
    "./scroll": {
      "import": "./dist/scroll.js",
      "require": "./dist/scroll.cjs",
      "types": "./dist/scroll.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "require": "./dist/router.cjs",
      "types": "./dist/router.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs",
      "types": "./dist/plugins.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs",
      "types": "./dist/ui.d.ts"
    },
    "./themes": {
      "import": "./dist/themes.js",
      "require": "./dist/themes.cjs",
      "types": "./dist/themes.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "types": "./dist/utils.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "require": "./dist/types.cjs",
      "types": "./dist/types.d.ts"
    },
    "./styles": "./dist/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && cp -r src/styles dist/styles",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "5.5.4",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "presentation",
    "slides",
    "fullscreen",
    "animation",
    "prezi",
    "deck",
    "talk"
  ]
}
