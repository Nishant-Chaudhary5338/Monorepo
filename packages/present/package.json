{
  "name": "@repo/present",
  "version": "0.0.1",
  "description": "Production-grade React presentation library — layouts, fullscreen, animations, Prezi-like web presentations, and beautiful components.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "types": "./dist/core/index.d.ts"
    },
    "./state": {
      "import": "./dist/state/index.js",
      "require": "./dist/state/index.cjs",
      "types": "./dist/state/index.d.ts"
    },
    "./animation": {
      "import": "./dist/animation/index.js",
      "require": "./dist/animation/index.cjs",
      "types": "./dist/animation/index.d.ts"
    },
    "./gestures": {
      "import": "./dist/gestures/index.js",
      "require": "./dist/gestures/index.cjs",
      "types": "./dist/gestures/index.d.ts"
    },
    "./scroll": {
      "import": "./dist/scroll/index.js",
      "require": "./dist/scroll/index.cjs",
      "types": "./dist/scroll/index.d.ts"
    },
    "./router": {
      "import": "./dist/router/index.js",
      "require": "./dist/router/index.cjs",
      "types": "./dist/router/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs",
      "types": "./dist/plugins/index.d.ts"
    },
    "./ui": {
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs",
      "types": "./dist/ui/index.d.ts"
    },
    "./themes": {
      "import": "./dist/themes/index.js",
      "require": "./dist/themes/index.cjs",
      "types": "./dist/themes/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs",
      "types": "./dist/utils/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./styles": "./dist/styles/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && cp -r src/styles dist/styles",
    "dev": "tsup --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "framer-motion": "^11.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "presentation",
    "slides",
    "fullscreen",
    "animation",
    "prezi",
    "deck",
    "talk"
  ]
}
